{
  "name": "video-translate-bot",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "./src/index.ts",
  "scripts": {
    "build": "pnpm tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:strict": "eslint 'src/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "command:js": "node",
    "command:ts": "pnpm tsx",
    "run:js": "pnpm command:js ./build/index.js",
    "run:ts": "pnpm command:ts .",
    "run:cli": "pnpm command:ts ./src/cli.ts",
    "run:deamon": "pnpm nodemon --exec \"pnpm command:ts\" --watch \"./.env\" --watch \"./src\" .",
    "dev": "APP_ENV='local' NODE_ENV='development' pnpm run:deamon",
    "dev:prod": "APP_ENV='local' NODE_ENV='production' pnpm run:deamon",
    "bot:init": "NODE_ENV='production' pnpm command:ts ./src/init.ts",
    "start": "NODE_ENV=production pnpm run:js",
    "start:dev": "NODE_ENV=development pnpm run:js",
    "dev:deamon": "NODE_ENV=development pnpm _dev:deamon:command",
    "dev:prod:deamon": "NODE_ENV=production pnpm _dev:deamon:command",
    "env:pull": "rclone sync yandex-cloud-nezort11:video-translate-bot-env ./env --progress",
    "env:push": "rclone sync ./env yandex-cloud-nezort11:video-translate-bot-env --progress",
    "s3:env:pull": "rclone sync yandex-cloud-nezort11:video-translate-bot-env ./yc_env --progress",
    "s3:env:push": "rclone sync ./yc_env yandex-cloud-nezort11:video-translate-bot-env --progress",
    "s3:storage:pull": "rclone sync yandex-cloud-nezort11:video-translate-bot-storage ./yc_storage --progress",
    "s3:storage:push": "rclone sync ./yc_storage yandex-cloud-nezort11:video-translate-bot-storage --progress",
    "s3:deps:sync": "rclone sync ./node_modules_prod yandex-cloud-nezort11:video-translate-bot-deps/node_modules --progress --transfers 32 --checkers 32 --exclude '.cache/**' --exclude '.bin/**'",
    "npm:install": "if [ \"$(uname -m)\" = \"x86_64\" ]; then npm install --omit=dev --force --no-package-lock; else docker run --rm --platform=linux/amd64 -w /app -v \"$(pwd)/package.json:/app/package.json\" -v \"$(pwd)/node_modules:/app/node_modules\" node:18 bash -c \"npm install --omit=dev --force --no-package-lock\"; fi",
    "npm:pre": "rm -rf node_modules && mkdir -p node_modules_prod && mv node_modules_prod node_modules",
    "npm:post": "if [ -d node_modules ] && [ ! -L node_modules ]; then rm -rf node_modules_prod && mv node_modules node_modules_prod; fi; ln -snf node_modules_dev node_modules",
    "npm:reinstall": "pnpm npm:pre && pnpm npm:install && pnpm npm:post",
    "app:package": "rm -f ./video-translate-bot.zip && zip -r ./video-translate-bot.zip ./node_modules ./build ./locales",
    "app:package:no-deps": "rm -f ./video-translate-bot.zip && zip -r ./video-translate-bot.zip ./package.json ./build ./locales",
    "video-translate-bot:upload": "yc storage s3api put-object --bucket video-translate-bot-code --key function.zip --body ./video-translate-bot.zip",
    "video-translate-bot:rebuild": "npm rebuild better-sqlite3 --target_platform=linux --target_arch=x64",
    "video-translate-bot:ci": "pnpm build && pnpm npm:pre && pnpm npm:install && pnpm app:package && pnpm npm:post && pnpm video-translate-bot:upload",
    "video-translate-bot:ci:cached": "pnpm build && pnpm npm:pre && pnpm app:package && pnpm npm:post && pnpm video-translate-bot:upload",
    "video-translate-bot:deploy": "cd ../.. && pnpm tf apply -target=yandex_function.video-translate-bot-function -target=yandex_message_queue.video-translate-bot-function-queue -target=yandex_function_trigger.video-translate-bot-function-queue-trigger -target=yandex_api_gateway.video-translate-bot-function-gateway -auto-approve",
    "video-translate-bot:deploy:full": "pnpm video-translate-bot:ci && pnpm video-translate-bot:deploy",
    "video-translate-bot:deploy:full:cached": "pnpm video-translate-bot:ci:cached && pnpm video-translate-bot:deploy",
    "video-translate-bot:ci:mounted": "pnpm build && pnpm s3:deps:sync && pnpm app:package:no-deps && pnpm video-translate-bot:upload",
    "video-translate-bot:deploy:mounted": "pnpm video-translate-bot:ci:mounted && pnpm video-translate-bot:deploy",
    "webhook:info": ". ./env/.env && pnpm telegraf -m getWebhookInfo -t $BOT_TOKEN_PROD",
    "webhook:set": ". ./env/.env && pnpm telegraf -m setWebhook -t $BOT_TOKEN_PROD -D \"{ \\\"url\\\": \\\"https://$(cd ../.. && terraform output -raw video_translate_bot_gateway_domain)/webhook\\\", \\\"drop_pending_updates\\\": \\\"False\\\" }\"",
    "webhook:set:clean": ". ./env/.env && pnpm telegraf -m setWebhook -t $BOT_TOKEN_PROD -D \"{ \\\"url\\\": \\\"https://$(cd ../.. && terraform output -raw video_translate_bot_gateway_domain)/webhook\\\", \\\"drop_pending_updates\\\": \\\"True\\\" }\"",
    "webhook:delete": ". ./env/.env && pnpm telegraf -m deleteWebhook -t $BOT_TOKEN_PROD",
    "test": "jest",
    "test:thumbnail": "jest src/__tests__/thumbnail.integration.test.ts --runInBand",
    "_command": "DEBUG='*' node --experimental-specifier-resolution=node --no-warnings",
    "_dev:command": "pnpm _command --inspect --loader ts-node/esm ./src/index.ts",
    "_dev": "NODE_ENV='development' pnpm _dev:command",
    "_dev:prod": "NODE_ENV='production' pnpm _dev:command",
    "_dev:deamon:command": "pnpm nodemon --exec \"pnpm _command --inspect --loader ts-node/esm\" --watch \"./.env\" --watch \"./src\" ./src/index.ts",
    "command": "node --experimental-specifier-resolution=node --no-warnings",
    "_cli": "NODE_ENV=development node --experimental-specifier-resolution=node --no-warnings --loader ts-node/esm ./src/cli.ts $url",
    "cli": "pnpm _cli"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.717.0",
    "@telegraf/session": "2.0.0-beta.7",
    "axios": "1.3.4",
    "cors": "2.8.5",
    "debug": "^4.3.4",
    "dotenv": "16.0.3",
    "express": "4.18.2",
    "fluent-ffmpeg": "2.1.3",
    "i18next": "24.2.2",
    "i18next-fs-backend": "2.6.0",
    "js-yaml": "4.1.0",
    "link-preview-js": "3.0.5",
    "nanoid": "3.3.4",
    "openai": "6.9.0",
    "p-retry": "6.2.1",
    "p-timeout": "^6.1.2",
    "pino": "8.14.1",
    "pino-pretty": "10.0.0",
    "protobufjs": "7.4.0",
    "s3-localstorage": "1.3.0",
    "serialize-error": "11.0.3",
    "serverless-http": "3.2.0",
    "telegraf": "4.16.3",
    "telegraf-session-store-ydb": "1.0.4",
    "telegraf-throttler": "0.6.0",
    "telegram": "2.15.15",
    "undici": "7.3.0",
    "ydb-sdk": "5.11.1"
  },
  "devDependencies": {
    "@distube/ytdl-core": "4.16.4",
    "@types/aws-lambda": "8.10.160",
    "@types/debug": "^4.1.12",
    "@types/express": "4.17.17",
    "@types/fluent-ffmpeg": "2.1.27",
    "@types/jest": "^29.5.11",
    "@types/node": "18.15.3",
    "@types/node-persist": "^3",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "@yandex-cloud/function-types": "2.1.2",
    "@yandex-cloud/serverless-plugin": "1.7.25",
    "abort-controller": "^3.0.0",
    "bottleneck": "^2.19.5",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "^29.7.0",
    "nodemon": "2.0.20",
    "prettier": "3.8.0",
    "serverless": "3.40.0",
    "ts-jest": "^29.1.1",
    "ts-node": "10.9.1",
    "tsx": "4.19.2",
    "typescript": "5.4.5"
  }
}
