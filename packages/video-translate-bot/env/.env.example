# 🚨 IMPORTANT: After editing the actual .env file, you MUST run:
# pnpm run env:push
# to sync the local environment to the Yandex Cloud S3 bucket.

# Environment loading configuration
# NOTE: APP_ENV should NOT be set in .env. It is provided by Terraform (main.tf) in production
# or passed via CLI (e.g. APP_ENV=local pnpm dev) during local development.
DEBUG="telegraf:*,-telegraf:client"
DEBUG_ENV=true

# Server configuration
PORT=3000

# Telegram Bot API credentials
BOT_TOKEN_PROD=""
BOT_TOKEN_DEV=""
BOT_PUBLIC_USERNAME="" # e.g. @vidtransbot
OWNER_USERNAME=""     # e.g. @vidadmin
ADMIN_IDS=""           # Comma-separated user IDs: 123456,789012

# Telegram MTProto (GramJS) configuration
APP_ID=""
APP_HASH=""
# Session strings generated via GramJS (npx tglogin)
# +888 0000 0000
# NOTE: Active sessions are now managed in 'telegram_sessions.json'.
# The placeholders below are deprecated and can be ignored.

# Telegram client proxy (SOCKS5/HTTP)
# IMPORTANT: The proxy MUST support direct IP connections (e.g. to Telegram DC IPs).
# Avoid IPv6-only proxies as they often only allow domain-based connections via remote DNS,
# which will NOT work with GramJS/MTProto (which connect directly to IPv4 DC addresses).
# Use socks5://username:password@ip:port
PROXY_SERVER_URI=""

# Yandex Cloud (YC) Database (YDB)
YDB_ENDPOINT="grpcs://ydb.serverless.yandexcloud.net:2135"
YDB_DATABASE="/ru-central1/..."

# Yandex Cloud (YC) Translate API
# Create service account with ai.translate.user role and generate API-key for authentication
# See: https://yandex.cloud/ru/docs/translate/api-ref/authentication#service-account_1
YC_API_KEY=""
YC_FOLDER_ID=""

# Yandex Cloud Object Storage (S3)
AWS_REGION="ru-central1"
AWS_S3_ENDPOINT="https://storage.yandexcloud.net"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
STORAGE_BUCKET="video-translate" # Bucket for final translated videos
YTDL_STORAGE_BUCKET="ytdl-service" # Bucket for YouTube worker file storage

# Internal Service URLs
# VTRANS_SERVICE_URL: The main video translation worker endpoint
VTRANS_SERVICE_URL="https://functions.yandexcloud.net/..."
# YTDL_API_BASE_URL: YouTube downloader worker endpoint
YTDL_API_BASE_URL="https://functions.yandexcloud.net/..."
# YTDL_FUNCTION_URL: Direct URL to the YTDL cloud function (overrides YTDL_API_BASE_URL)
YTDL_FUNCTION_URL=""
# WORKER_APP_SERVER_URL: Base URL for the containerized worker
WORKER_APP_SERVER_URL="https://..."

# External API Integrations
OPENAI_API_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="sk-..."

# Edge HTTP Proxy for YouTube thumbnails (useful for bypassing country blocks)
EHP_PROXY="https://your-edge-proxy.com/"

# Media Storage & Logging Channels
# Telegram IDs can be obtained via @chatIDrobot or by "Copy message link"
STORAGE_CHANNEL_ID=""   # Channel where the bot stores uploaded/translated media
LOGGING_CHANNEL_ID=""   # Channel for general system logs
ALERTS_CHANNEL_ID=""    # Channel for critical error alerts
DEBUG_USER_CHAT_ID=""   # Developer User ID for direct debug notifications

# Bot Behavior Limits
MAX_VIDEO_DURATION_MINUTES="70"
EXECUTION_TIMEOUT="1800" # Global operation timeout in seconds (30 minutes)

