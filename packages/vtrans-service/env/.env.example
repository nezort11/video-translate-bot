YANDEX_TRANSLATE_HMAC_SHA254_SECRET=""

# Required ONLY for Live/Neural voices translation.
# To retrieve this safely, use the "Get cookies.txt LOCALLY" extension
# (https://chromewebstore.google.com/detail/get-cookiestxt-locally/cclelndahbckbenkjhflpdbgdldlbecc).
# 1. Be on the ya.ru page while logged in.
# 2. Click the extension, set Export Format to "Header String".
# 3. Copy the string and paste it into this variable.
# YANDEX_COOKIES_HEADER_STRING=""
# Use Oauth access token instead!!

# Required ONLY for Live/Neural voices translation on certain videos
# 1. Log in to your Yandex account (if you aren't already).
# 2. Go to https://oauth.yandex.ru/authorize?response_type=token&client_id=23cabbbdc6cd418abb4b39c32c41195d
# 3. It might ask you to solve a quick CAPTCHA ("Я не робот").
# 4. After that, look closely at the URL in your browser's address bar. It will change to something like:
#    https://music.yandex.ru/#access_token=...&token_type=bearer...
# 5. Copy the long token string just after `access_token=` (make sure not to copy the `&token_type...` part).
YANDEX_OAUTH_ACCESS_TOKEN=""
