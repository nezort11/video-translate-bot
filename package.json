{
  "name": "video-translate-bot-monorepo",
  "private": true,
  "volta": {
    "node": "18.20.2"
  },
  "packageManager": "pnpm@8.3.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "tf": ". ./packages/video-translate-bot/env/.env && . ./terraform.env && terraform",
    "bot:dev": "pnpm --filter video-translate-bot dev",
    "bot:build": "pnpm --filter video-translate-bot build",
    "bot:cli": "pnpm --filter video-translate-bot cli",
    "bot:deploy": "pnpm --filter video-translate-bot video-translate-bot:deploy",
    "bot:deploy:full": "pnpm --filter video-translate-bot video-translate-bot:deploy:full",
    "bot:deploy:full:cached": "pnpm --filter video-translate-bot video-translate-bot:deploy:full:cached",
    "bot:deploy:bundle": "pnpm --filter video-translate-bot video-translate-bot:deploy:bundle",
    "bot:reinstall": "pnpm --filter video-translate-bot npm:reinstall",
    "admin:api:build": "pnpm --filter admin-api build",
    "admin:api:ci": "pnpm --filter admin-api ci",
    "admin:api:cd": "pnpm --filter admin-api cd",
    "admin:api:cicd": "pnpm --filter admin-api cicd",
    "admin:dashboard:dev": "pnpm --filter admin-dashboard dev",
    "admin:dashboard:build": "pnpm --filter admin-dashboard build",
    "admin:dashboard:deploy": "pnpm --filter admin-dashboard deploy",
    "vtrans:build": "pnpm --filter vtrans-service build",
    "vtrans:ci": "pnpm --filter vtrans-service ci",
    "vtrans:cd": "pnpm --filter vtrans-service cd",
    "vtrans:cicd": "pnpm --filter vtrans-service cicd",
    "env:backup": "zip -r env-artifacts.zip terraform.tfstate* state.json .terraform.lock.hcl main.tf variables.tf outputs.tf metrics.tf package.json pnpm-workspace.yaml pnpm-lock.yaml terraform.env .env_remote packages/video-translate-bot/env/ packages/vtrans-service/env/ packages/admin-api/env/ && yc storage s3api put-object --bucket nezort11-bot-env --key video-translate-bot/env-artifacts.zip --body ./env-artifacts.zip && rm env-artifacts.zip",
    "env:restore": "yc storage s3api get-object --bucket nezort11-bot-env --key video-translate-bot/env-artifacts.zip env-artifacts.zip && unzip -o env-artifacts.zip && rm env-artifacts.zip",
    "bot:env:push": "pnpm --filter video-translate-bot env:push",
    "bot:env:pull": "pnpm --filter video-translate-bot env:pull"
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "8.0.3",
    "lint-staged": "15.4.3",
    "prettier": "3.8.0",
    "typescript": "5.4.5"
  },
  "husky": {
    "hooks": {
      "post-checkout": "yarnhook",
      "post-merge": "yarnhook",
      "post-rewrite": "yarnhook"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
